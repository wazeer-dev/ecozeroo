rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. PRODUCTS: Public viewing and open updates for stock/catalog management.
    match /products/{productId} {
      allow read, write: if true;
    }

    // 2. NOTIFICATIONS (Broadcasts): Open for system-wide alerts and admin dashboard management.
    match /notifications/{notifId} {
      allow read, write, delete: if true;
    }

    // 3. USERS (Profiles): Open for signup, login sync, and profile management across devices.
    match /users/{userId} {
      allow read, write, delete: if true;
    }

    // 4. ORDERS: Open for customer checkout processing and administrative order fulfillment.
    match /orders/{orderId} {
      allow read, write, delete: if true;
    }
    
    // 5. REVIEWS: Open for product feedback publishing and global sentiment analysis.
    match /reviews/{reviewId} {
      allow read, write, delete: if true;
    }
    
    // 6. INTERACTIONS (New): Open for tracking 'One-Time-Use' states and voucher redemptions.
    match /interactions/{id} {
      allow read, write, delete: if true;
    }
  }
}
